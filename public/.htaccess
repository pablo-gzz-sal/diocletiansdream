# Diocletians Dream — static (prerendered Angular) hosting on Apache/SiteGround.
# The build in dist/diocletiansdream/browser/ is uploaded to the domain's
# document root. These rules reproduce the routing that used to live in the
# Node SSR server (src/server.ts).

Options -MultiViews
DirectoryIndex index.html

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Legacy /blog/<slug> URLs now live at the root — permanent redirect.
  # (Does not match the blog index "/blog/" itself.)
  RewriteRule ^blog/([^/]+)/?$ /$1/ [R=301,L]

  # Canonical trailing slash: add a slash to any non-file request that lacks
  # one, so /experience -> /experience/ (matches the prerendered folder URLs).
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} !\.[a-zA-Z0-9]+$
  RewriteCond %{REQUEST_URI} !/$
  RewriteRule ^(.*)$ /$1/ [R=301,L]

  # SPA fallback: a trailing-slash route with no prerendered folder (e.g. a blog
  # post published after the last build) is served the client-render shell so
  # the Angular app boots, reads the slug, and fetches the post live from
  # WordPress. Real files/dirs and asset URLs are excluded, so they still serve
  # directly or 404 normally. Unknown-but-invalid slugs render the in-app
  # not-found state (noindex). Rebuilding bakes real posts into static files.
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} /$
  RewriteRule ^ /index.csr.html [L]
</IfModule>

# Fallback 404 for non-route requests (e.g. a missing asset with an extension).
ErrorDocument 404 /404/index.html

# Long-lived caching for fingerprinted build assets.
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
</IfModule>
